# Metricord Configuration Example
# Zkopírujte tento soubor do .env a vyplňte skutečné údaje.

# --- Discord ---
BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN"
DASHBOARD_TOKEN="YOUR_DASHBOARD_BOT_TOKEN"
GUILD_ID="YOUR_GUILD_ID"
DISCORD_CLIENT_SECRET="YOUR_CLIENT_SECRET"

# --- Channels ---
ALERT_CHANNEL_ID="YOUR_ALERT_CHANNEL_ID"
CONSOLE_CHANNEL_ID="YOUR_CONSOLE_CHANNEL_ID"
VERIFICATION_CHANNEL_ID="YOUR_VERIFICATION_CHANNEL_ID"
VERIFICATION_LOG_CHANNEL_ID="YOUR_VERIFICATION_LOG_CHANNEL_ID"
WELCOME_CHANNEL_ID="YOUR_WELCOME_CHANNEL_ID"

# --- Roles ---
VERIFIED_ROLE_ID="YOUR_VERIFIED_ROLE_ID"

# --- Infrastructure ---
REDIS_URL="redis://redis:6379/0"
KC_INTERNAL_URL="http://keycloak:8080"
KC_ADMIN_PASSWORD="YOUR_KEYCLOAK_ADMIN_PASSWORD"

# --- Features ---
BOT_LITE_MODE=1
VERIFICATION_CODE="Restart"

# --- Dashboard & External ---
DASHBOARD_SECRET_KEY="GENERATE_A_RANDOM_STRING"
DASHBOARD_ACCESS_TOKEN="YOUR_DASHBOARD_ACCESS_TOKEN"
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"
SMTP_PASSWORD="YOUR_SMTP_PASSWORD"
